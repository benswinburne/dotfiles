#!/usr/bin/env bash
set -euo pipefail

DOTFILES="$HOME/.dotfiles"
SETUP="$DOTFILES/Setup"
CHECKPOINT_FILE="$HOME/.dotfiles_setup_progress"

# Colours
GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'; NC='\033[0m'

# Ask for sudo upfront and keep it alive
sudo -v
while true; do sudo -n true; sleep 60; kill -0 "$$" || exit; done 2>/dev/null &

step() {
  local name="$1"
  local script="$SETUP/$2"

  if grep -qxF "$name" "$CHECKPOINT_FILE" 2>/dev/null; then
    echo -e "${YELLOW}⏭  Skipping${NC} $name"
    return 0
  fi

  echo -e "\n▶  Running $name..."

	# Ensure brew is in PATH regardless of whether bash_profile is symlinked yet
	if [[ -f /opt/homebrew/bin/brew ]]; then
		eval "$(/opt/homebrew/bin/brew shellenv)"
	elif [[ -f /usr/local/bin/brew ]]; then
		eval "$(/usr/local/bin/brew shellenv)"
	fi

  # Each script runs as a subprocess in its own shell, always starting
  # from DOTFILES dir. pushd/popd in sub-scripts can't affect us.
  if (cd "$DOTFILES" && bash "$script"); then
    echo "$name" >> "$CHECKPOINT_FILE"
    echo -e "${GREEN}✓  $name done${NC}"
    read -rp "Press enter to continue to next step..."
  else
    echo -e "${RED}✗  $name FAILED${NC}"
    echo -e "   Fix the issue and re-run — progress is saved."
    exit 1
  fi
}

step "xcode-bootstrap"     xcode-bootstrap   # xcode-select --install, no mas
step "homebrew"            homebrew
# step "xcode"               xcode             # mas install, license, packages
step "osx-preferences"     osx-preferences
step "cleanup-dock"        cleanup-dock
step "restart-osx-services" restart-osx-services
step "open-applications"   open-applications
step "php-composer"        php-composer
step "local-certificates"  local-certificates
step "fzf"                 fzf
step "yarn-global"         yarn-global
step "symlinks"            symlinks
step "ssh"                 ssh
step "vim-setup"           vim-setup
step "tmux-setup"          tmux-setup
step "docker"              docker
step "osx-default-apps"    osx-default-apps
step "osx-finder-shortcuts" osx-finder-shortcuts
step "mysql-shutdown"      mysql-shutdown
step "pip-tools"           pip-tools
step "dotfiles-remote"     dotfiles-remote
step "shell-change"        shell-change
step "brew-cleanup"        brew-cleanup
step "mas-apps"             mas-apps

echo -e "\n${GREEN}All done! Delete $CHECKPOINT_FILE to re-run from scratch.${NC}"
