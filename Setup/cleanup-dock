#!/usr/bin/env bash

brew install dockutil

# Clean up the default dock programs
for app in \
  'System Preferences' \
  'System Settings' \
  'Music' \
  'iBooks' \
  'App Store' \
  'Photos' \
  'Maps' \
  'Messages' \
  'Reminders' \
  'Contacts' \
  'Calendar' \
  'Siri' \
  'Safari' \
  'Mail' \
  'Launchpad' \
  'Notes' \
  'FaceTime' \
  'Downloads' \
  'Numbers' \
  'Keynote' \
  'Pages' \
  'News' \
  'TV' \
  'Podcasts'; do
  dockutil --remove "$app" --allhomes 2>/dev/null
done

dockutil --add /Applications/Google\ Chrome.app --position 1
dockutil --add /Applications/iTerm.app --position 2
dockutil --add /Applications/Slack.app --position 4

brew uninstall dockutil
