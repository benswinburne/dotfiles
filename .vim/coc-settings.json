{
  "explorer.sources": [
    {
      "name": "buffer",
      "expand": false
    },
    {
      "name": "file",
      "expand": true
    }
  ],
  "explorer.keyMappings.global": {
    "<cr>": [
      "expanded?",
      "collapse",
      "expand"
    ],
    "m": [
      "actionMenu"
    ],
    "<C-o>": [
      "cd"
    ]
  },
  "explorer.position": "right",
  "explorer.previewAction.onHover": false,
  "explorer.width": 40,
  "explorer.icon.enableNerdfont": true,
  "explorer.file.showHiddenFiles": true,
  "typescript.suggestionActions.enabled": false,
  "typescript.suggest.enabled": false,
  "typescript.validate.enable": true,
  "javascript.suggest.enabled": false,
  "javascript.validate.enable": false,
  "diagnostic.enableMessage": "never",
  "diagnostic.displayByAle": true,
  "inlayHint.display": false,
  "inlayHint.enable": false,
  "intelephense.diagnostics.enable": true,
  "diagnostic.messageTarget": "float",
  "diagnostic.virtualText": false,
  "diagnostic.virtualTextCurrentLineOnly": true,
  "snippets.loadFromExtensions": true,
  "snippets.extends": {
    "javascriptreact": [
      "javascript"
    ],
    "typescriptreact": [
      "javascript"
    ],
    "typescript": [
      "javascript"
    ]
  },
  "phpls.path": "/Users/ben/.npm-packages/bin/intelephense",
  "phpls.enable": true,
  "suggest.timeout": 500,
  "suggest.noselect": true,
  "suggest.maxCompleteItemCount": 30,
  "languageserver": {
    "dockerfile": {
      "command": "docker-langserver",
      "filetypes": [
        "dockerfile"
      ],
      "args": [
        "--stdio"
      ]
    }
  },
  "intelephense.licenceKey": "~/Dropbox/.private/intelephense.txt",
  "intelephense.environment.phpVersion": "8.3.0",
  "yaml.customTags": [
    "!env_var scalar",
    "!include_dir_list scalar",
    "!include_dir_merge_list scalar",
    "!include_dir_merge_named scalar",
    "!include_dir_named scalar",
    "!include scalar",
    "!secret scalar"
  ],
  "tsserver.tsdk": "/Users/ben/.config/yarn/global/node_modules/typescript/lib"
}
