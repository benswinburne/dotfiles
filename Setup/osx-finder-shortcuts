#!/usr/bin/env bash

echo "Finder Shortcuts"

mkdir -p ~/Sites/work
mkdir -p ~/Sites/playground

# Build sbedit — modern replacement for mysides, works on macOS 15+
git clone https://github.com/fabienconus/sidebar-editor.git /tmp/sbedit
cd /tmp/sbedit
swift build -c release
SBEDIT=".build/release/sbedit"

$SBEDIT --add ~/Sites
$SBEDIT --add ~
$SBEDIT --reload --force

rm -rf /tmp/sbedit

