#!/usr/bin/env bash

# install homebrew if it's missing
if ! command -v brew >/dev/null 2>&1; then
  echo "Installing Homebrew"
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

eval "$(/opt/homebrew/bin/brew shellenv)"

/usr/sbin/softwareupdate --install-rosetta --agree-to-license

echo "Installing Homebrew Bundle"
brew bundle
brew bundle cleanup --force

softwareupdate --all --install --force

# x86 Homebrew for packages that don't have arm64 builds
# Note: worth checking if you still need this — most things have native arm64 now
if [[ ! -f /usr/local/homebrew/bin/brew ]]; then
  mkdir -p ~/Downloads/homebrew
  curl -L https://github.com/Homebrew/brew/tarball/master | tar xz --strip 1 -C ~/Downloads/homebrew
  sudo mv ~/Downloads/homebrew /usr/local/homebrew
fi

arch -x86_64 /usr/local/homebrew/bin/brew install java
